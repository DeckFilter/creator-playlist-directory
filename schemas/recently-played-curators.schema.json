{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deckfilter.github.io/creator-playlist-directory/schemas/recently-played-curators.schema.json",
  "title": "Recently Played Curators",
  "type": "object",
  "required": ["schemaVersion", "cards"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["creatorId", "steamId", "title", "image", "placement", "products", "productSort"],
        "properties": {
          "creatorId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "steamId": { "type": "string", "pattern": "^[0-9]{17}$" },
          "title": { "type": "string", "minLength": 1, "maxLength": 80 },
          "image": { "type": "string" },
          "youtubeUrl": { "type": "string", "format": "uri" },
          "placement": { "enum": ["primary", "final"] },
          "products": {
            "type": "array",
            "items": { "enum": ["deckfilter", "decksettings"] },
            "minItems": 1,
            "uniqueItems": true
          },
          "productSort": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
