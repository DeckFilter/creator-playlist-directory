{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deckfilter.github.io/creator-database/schemas/featured-playlist.schema.json",
  "title": "Featured Playlist",
  "type": "object",
  "required": ["schemaVersion", "playlistId", "status", "title", "description", "appIds", "products", "productSort"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "playlistId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "status": { "enum": ["active", "paused"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "description": { "type": "string", "minLength": 1, "maxLength": 280 },
    "creatorId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "appIds": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 1
    },
    "products": {
      "type": "array",
      "items": { "enum": ["deckfilter", "decksettings"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "productSort": { "type": "object" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
